{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "{projectRoot}/dist",
        "{projectRoot}/build",
        "{projectRoot}/src/built",
        "{projectRoot}/.next"
      ]
    },
    "test": {
      "dependsOn": []
    }
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx-cloud",
      "options": {
        "cacheableOperations": [],
        "accessToken": "YmQ0NjZjZWMtMDA2ZC00NGM1LThhZDMtOTE0OTFjYmQ0M2RjfHJlYWQtd3JpdGU="
      }
    }
  },
  "defaultBase": "main"
}
